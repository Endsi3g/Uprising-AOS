# ============================================================
# Uprising AOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Clerk Auth ---
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/os
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/os

# --- Anthropic / Claude API ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Brevo (optional — Phase 3) ---
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# --- Todoist (optional) ---
# Get from: https://todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=

# --- Metricool (optional) ---
# Get from: https://metricool.com/developer
METRICOOL_API_KEY=
# Blog ID from your Metricool workspace (visible in the dashboard URL)
METRICOOL_BLOG_ID=

# --- Brevo Webhook Security (optional) ---
# Set a secret token to validate incoming webhook requests
BREVO_WEBHOOK_SECRET=

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
